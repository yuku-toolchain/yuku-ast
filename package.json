{
  "name": "yuku-ast",
  "version": "0.1.2",
  "description": "A fast, typed AST toolkit for yuku-parser's ESTree / TypeScript-ESTree AST: node builders, type guards, a walker, and identifier validators.",
  "keywords": [
    "ast",
    "codemod",
    "estree",
    "javascript",
    "transform",
    "traverse",
    "typescript",
    "visitor",
    "walker",
    "yuku"
  ],
  "homepage": "https://yuku.fyi",
  "license": "MIT",
  "author": "Arshad Yaseen <arshadpyaseen@gmail.com> (https://arshad.fyi)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuku-toolchain/yuku-ast.git"
  },
  "funding": "https://github.com/sponsors/arshad-yaseen",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./identifier": "./dist/identifier.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "release": "bumpp -r --commit 'npm %s' --push --tag"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "yuku-codegen": "^0.5.18",
    "yuku-parser": "^0.5.18"
  },
  "peerDependencies": {
    "yuku-parser": ">=0.5.18"
  }
}
