{
  "name": "yuku-walk",
  "version": "0.0.1",
  "description": "A fast, typed AST walker for yuku-parser's ESTree / TypeScript-ESTree AST.",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "keywords": ["ast", "walker", "traverse", "visitor", "estree", "yuku", "typescript", "javascript", "transform", "codemod"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^5",
    "yuku-parser": "^0.5.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "yuku-codegen": "^0.5.16",
    "yuku-parser": "^0.5.16"
  }
}
